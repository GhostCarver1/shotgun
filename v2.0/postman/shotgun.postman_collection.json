    {
      "name": "Login",
      "item": [
        {
          "name": "Alice",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response time is under 2000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test(\"Response body is valid JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "pm.test(\"Response contains an auth token\", function () {",
                  "    const json = pm.response.json();",
                  "    const hasToken = json.token || json.access_token || json.jwt || json.sessionToken || json.id_token;",
                  "    pm.expect(hasToken).to.exist;",
                  "});",
                  "",
                  "pm.test(\"Response does not expose the password\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.not.have.property(\"password\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\":\"alice@example.com\",\n    \"password\":\"amicable\"\n}\n",
